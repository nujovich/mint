---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'button'> {
  variant?: 'primary' | 'secondary' | 'ghost' | 'danger';
  size?: 'sm' | 'md' | 'lg';
  disabled?: boolean;
  type?: 'button' | 'submit' | 'reset';
}

const { variant = 'primary', size = 'md', disabled = false, type = 'button', ...rest } = Astro.props;
---

<button
  class:list={['btn', `btn--${variant}`, `btn--${size}`]}
  type={type}
  disabled={disabled}
  {...rest}
>
  <slot />
</button>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: none;
    border-radius: var(--border-radius-md);
    font-family: var(--font-family-body);
    font-weight: var(--font-weight-bold);
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
    white-space: nowrap;
  }

  .btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .btn--sm {
    padding: var(--spacing-2) var(--spacing-3);
    font-size: 14px;
    line-height: 1.4;
  }

  .btn--md {
    padding: var(--spacing-3) var(--spacing-5);
    font-size: 16px;
    line-height: 1.5;
  }

  .btn--lg {
    padding: var(--spacing-5) var(--spacing-6);
    font-size: 18px;
    line-height: 1.6;
  }

  .btn--primary {
    background-color: var(--color-primary-500);
    color: white;
    box-shadow: var(--shadow-sm);
  }

  .btn--primary:hover:not(:disabled) {
    background-color: var(--color-primary-600);
  }

  .btn--primary:active:not(:disabled) {
    background-color: var(--color-primary-700);
  }

  .btn--secondary {
    background-color: var(--color-surface-500);
    color: var(--color-text-500);
    border: 1px solid var(--color-border-500);
  }

  .btn--secondary:hover:not(:disabled) {
    background-color: var(--color-background-300);
  }

  .btn--ghost {
    background-color: transparent;
    color: var(--color-primary-500);
  }

  .btn--ghost:hover:not(:disabled) {
    background-color: var(--color-primary-50);
  }

  .btn--danger {
    background-color: var(--color-error-500);
    color: white;
    box-shadow: var(--shadow-sm);
  }

  .btn--danger:hover:not(:disabled) {
    background-color: var(--color-error-600);
  }

  .btn--danger:active:not(:disabled) {
    background-color: var(--color-error-700);
  }
</style>

<!-- Usage example:
import Button from './Button.astro';
<Button variant="primary" size="md">Click me</Button>
<Button variant="danger" disabled>Disabled</Button>
-->

// --- Card.astro ---
---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'div'> {
  title?: string;
  description?: string;
  variant?: 'default' | 'elevated' | 'outlined';
}

const { title, description, variant = 'default', ...rest } = Astro.props;
---

<div class:list={['card', `card--${variant}`]} {...rest}>
  {title && (
    <div class="card__header">
      <h3 class="card__title">{title}</h3>
      {description && <p class="card__description">{description}</p>}
    </div>
  )}
  <div class="card__content">
    <slot />
  </div>
</div>

<style>
  .card {
    background-color: var(--color-surface-500);
    border-radius: var(--border-radius-md);
    overflow: hidden;
    font-family: var(--font-family-body);
  }

  .card--default {
    border: 1px solid var(--color-border-500);
  }

  .card--elevated {
    box-shadow: var(--shadow-sm);
  }

  .card--outlined {
    border: 2px solid var(--color-border-600);
  }

  .card__header {
    padding: var(--spacing-5) var(--spacing-6);
    border-bottom: 1px solid var(--color-border-500);
  }

  .card__title {
    margin: 0;
    color: var(--color-text-500);
    font-size: 18px;
    font-weight: var(--font-weight-bold);
    line-height: 1.4;
  }

  .card__description {
    margin: var(--spacing-2) 0 0 0;
    color: var(--color-muted-500);
    font-size: 14px;
    line-height: 1.5;
  }

  .card__content {
    padding: var(--spacing-5) var(--spacing-6);
  }

  .card__content:first-child {
    padding-top: var(--spacing-6);
  }
</style>

<!-- Usage example:
import Card from './Card.astro';
<Card title="Card Title" description="Card description" variant="elevated">
  <p>Card content goes here</p>
</Card>
-->

// --- Badge.astro ---
---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'span'> {
  variant?: 'primary' | 'secondary' | 'accent' | 'neutral' | 'success' | 'danger';
  size?: 'sm' | 'md';
}

const { variant = 'neutral', size = 'md', ...rest } = Astro.props;
---

<span class:list={['badge', `badge--${variant}`, `badge--${size}`]} {...rest}>
  <slot />
</span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--border-radius-sm);
    font-family: var(--font-family-body);
    font-weight: var(--font-weight-bold);
    white-space: nowrap;
    text-align: center;
  }

  .badge--sm {
    padding: var(--spacing-1) var(--spacing-2);
    font-size: 12px;
    line-height: 1.2;
  }

  .badge--md {
    padding: var(--spacing-2) var(--spacing-3);
    font-size: 14px;
    line-height: 1.3;
  }

  .badge--primary {
    background-color: var(--color-primary-500);
    color: white;
  }

  .badge--secondary {
    background-color: var(--color-background-600);
    color: var(--color-text-500);
  }

  .badge--accent {
    background-color: var(--color-primary-100);
    color: var(--color-primary-700);
  }

  .badge--neutral {
    background-color: var(--color-muted-200);
    color: var(--color-muted-700);
  }

  .badge--success {
    background-color: #10b981;
    color: white;
  }

  .badge--danger {
    background-color: var(--color-error-500);
    color: white;
  }
</style>

<!-- Usage example:
import Badge from './Badge.astro';
<Badge variant="primary" size="md">New</Badge>
<Badge variant="danger" size="sm">Error</Badge>
-->

// --- Input.astro ---
---
import type { HTMLAttributes } from 'astro/types';

interface Props extends Omit<HTMLAttributes<'input'>, 'type' | 'size'> {
  label?: string;
  placeholder?: string;
  value?: string;
  error?: string;
  hint?: string;
  disabled?: boolean;
  type?: 'text' | 'email' | 'password' | 'number' | 'tel' | 'url' | 'search';
  name?: string;
  id?: string;
}

const {
  label,
  placeholder,
  value,
  error,
  hint,
  disabled = false,
  type = 'text',
  name,
  id,
  ...rest
} = Astro.props;

const inputId = id || name || `input-${Math.random().toString(36).substr(2, 9)}`;
---

<div class="input-group">
  {label && (
    <label for={inputId} class="input__label">
      {label}
    </label>
  )}
  <input
    id={inputId}
    class:list={['input', { 'input--error': error }]}
    type={type}
    name={name}
    placeholder={placeholder}
    value={value}
    disabled={disabled}
    {...rest}
  />
  {hint && !error && (
    <p class="input__hint">{hint}</p>
  )}
  {error && (
    <p class="input__error">{error}</p>
  )}
</div>

<style>
  .input-group {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
    font-family: var(--font-family-body);
  }

  .input__label {
    font-size: 14px;
    font-weight: var(--font-weight-bold);
    color: var(--color-text-500);
    line-height: 1.4;
  }

  .input {
    padding: var(--spacing-3) var(--spacing-5);
    border: 1px solid var(--color-border-500);
    border-radius: var(--border-radius-md);
    font-size: 16px;
    line-height: 1.5;
    color: var(--color-text-500);
    background-color: var(--color-surface-500);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .input:focus {
    outline: none;
    border-color: var(--color-primary-500);
    box-shadow: 0 0 0 2px var(--color-primary-100);
  }

  .input:disabled {
    background-color: var(--color-background-300);
    color: var(--color-muted-400);
    cursor: not-allowed;
  }

  .input--error {
    border-color: var(--color-error-500);
  }

  .input--error:focus {
    border-color: var(--color-error-500);
    box-shadow: 0 0 0 2px var(--color-error-100);
  }

  .input__hint {
    margin: 0;
    font-size: 12px;
    color: var(--color-muted-500);
    line-height: 1.4;
  }

  .input__error {
    margin: 0;
    font-size: 12px;
    color: var(--color-error-500);
    line-height: 1.4;
  }

  .input::placeholder {
    color: var(--color-muted-400);
  }
</style>

<!-- Usage example:
import Input from './Input.astro';
<Input
  label="Email"
  type="email"
  placeholder="Enter your email"
  name="email"
  hint="We'll never share your email"
/>
<Input
  label="Password"
  type="password"
  error="Password is required"
/>
-->
